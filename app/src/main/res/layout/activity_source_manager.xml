<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d0d1a"
    android:orientation="vertical">

    <!-- 顶部操作栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvFilterTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="全部源"
            android:textColor="#E0E0EE"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnAddSource"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/shape_btn_confirm"
            android:gravity="center"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:text="+ 添加"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 过滤标签 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingBottom="12dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/btnAll"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginRight="6dp"
            android:background="@drawable/shape_setting_model_focus"
            android:gravity="center"
            android:text="全部"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btnVideo"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginLeft="3dp"
            android:layout_marginRight="3dp"
            android:background="@drawable/shape_setting_model_focus"
            android:gravity="center"
            android:text="🎬 视频"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btnLive"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginLeft="3dp"
            android:layout_marginRight="3dp"
            android:background="@drawable/shape_setting_model_focus"
            android:gravity="center"
            android:text="📺 直播"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btnGame"
            android:layout_marginLeft="3dp"
            android:layout_marginRight="3dp"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginLeft="6dp"
            android:background="@drawable/shape_setting_model_focus"
            android:gravity="center"
            android:text="🎮 游戏"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- 源列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/sourceRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingLeft="16dp"
        android:paddingRight="16dp" />

    <!-- 提示 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:text="长按可编辑，左滑可删除"
        android:textColor="#6B6B80"
        android:textSize="12sp" />
</LinearLayout>
